---
import Callout from "blume/components/content/Callout.astro";
import { contentHref } from "blume/components/content/base-href.ts";
---

<section>
  <p
    class="mb-3 text-center font-semibold text-muted-foreground text-xs uppercase tracking-wider"
  >
    Stability
  </p>
  <Callout title="Experimental" type="warning">
    <p>
      Experimental — the API may change between minor releases. Pin your
      version.
    </p>
    <p class="mt-3">
      <a class="font-medium text-accent" href={contentHref("/concepts/stability")}>
        Stability & versioning
      </a>
      {" · "}
      <a class="font-medium text-accent" href={contentHref("/reference/migration")}>
        Migration guide
      </a>
    </p>
  </Callout>
</section>
