---
import Card from "blume/components/content/Card.astro";
import CardGroup from "blume/components/content/CardGroup.astro";
import { contentHref } from "blume/components/content/base-href.ts";

/** Card is `not-prose` — Blume chips don't apply; style explicitly. */
const codeChip =
  "rounded bg-muted px-1 font-mono text-xs text-foreground";
---

<section>
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="font-medium text-3xl tracking-tight sm:text-4xl">
      Batteries included.
    </h2>
    <p class="mx-auto mt-4 max-w-lg text-balance text-muted-foreground">
      Handle the overlay cases that stop being local: ordered stacks,
      one-at-a-time flows, nested dialogs, guarded closes, and validated input.
      Adopt only the pieces your UI needs.
    </p>
  </div>

  <div class="mt-10">
    <CardGroup cols={3}>
      <Card
        arrow
        href={contentHref("/concepts/overview")}
        icon="layers"
        title="Partition overlays into ordered stacks"
      >
        Partition overlays by purpose — confirm, toast, drawer — each an ordered
        stack with its own z-order and lifecycle.
      </Card>
      <Card
        arrow
        href={contentHref("/concepts/lifecycle")}
        icon="zap"
        title="Open and update from anywhere"
      >
        Push, replace singletons, patch live payloads, and dismiss from anywhere
        — no lifted <code class={codeChip}>isOpen</code> state.
      </Card>
      <Card
        arrow
        href={contentHref("/guides/awaiting-results")}
        icon="tag"
        title="Await a result — no call-site generics"
      >
        <code class={codeChip}>{"await confirm.open({ title })"}</code> on a
        wired handle — <code class={codeChip}>R</code> flows from the key brand.
      </Card>
      <Card
        arrow
        href={contentHref("/guides/serial-queues")}
        icon="list-ordered"
        title="Run flows one at a time"
      >
        One-at-a-time flows with{" "}
        <code class={codeChip}>{"scope: { strategy: 'serial' }"}</code> and a
        snapshot of what's waiting.
      </Card>
      <Card
        arrow
        href={contentHref("/guides/nested-overlays")}
        icon="git-branch"
        title="Nest overlays without prop-drilling"
      >
        Nested stacks for drawer → sub-dialog flows via{" "}
        <code class={codeChip}>useLayerGroup</code> /{" "}
        <code class={codeChip}>createLayerGroup</code>.
      </Card>
      <Card
        arrow
        href={contentHref("/guides/animations")}
        icon="sparkles"
        title="Animate enter and exit"
      >
        Enter/exit phases with delay timers and{" "}
        <code class={codeChip}>call.settle()</code> for animated overlays.
      </Card>
      <Card
        arrow
        href={contentHref("/guides/dismissal-blockers")}
        icon="shield"
        title="Guard against accidental close"
      >
        Gate user-intent dismissal with{" "}
        <code class={codeChip}>addBlocker</code>,{" "}
        <code class={codeChip}>dismissing</code>, and{" "}
        <code class={codeChip}>dismissAll</code> modes.
      </Card>
      <Card
        arrow
        href={contentHref("/guides/payload-validation")}
        icon="check-circle"
        title="Validate payloads at open"
      >
        Parse untrusted payloads at <code class={codeChip}>open</code> with
        Standard Schema or a sync function — rejects with{" "}
        <code class={codeChip}>PayloadValidationError</code>.
      </Card>
      <Card
        arrow
        href={contentHref("/adapters/core")}
        icon="box"
        title="No framework in the core"
      >
        UI-agnostic <code class={codeChip}>LayerClient</code> engine — framework
        adapters subscribe via their native reactivity primitives.
      </Card>
    </CardGroup>
  </div>
</section>
