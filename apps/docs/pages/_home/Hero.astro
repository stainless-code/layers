---
import CodeBlock from "blume/components/content/CodeBlock.astro";
import Icon from "blume/components/Icon.astro";
import { contentHref } from "blume/components/content/base-href.ts";
import HeroDemo from "../../islands/HeroDemo.tsx";
import { adapterSnippets } from "./adapter-snippets.ts";
import InstallBox from "./InstallBox.astro";

const pillBase =
  "cursor-pointer rounded-full border px-3 py-1 text-xs transition active:scale-[0.97] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent/40";
const pillActive =
  "border-accent bg-accent/10 font-medium text-accent";
const pillMuted =
  "border-border text-muted-foreground hover:border-foreground/40 hover:text-foreground";
const defaultFramework = "vanilla";
---

<section class="text-center">
  <a
    class="inline-flex items-center rounded-full border border-border px-3 py-1 text-muted-foreground text-xs transition-colors hover:border-foreground hover:text-foreground"
    href={contentHref("/concepts/stability")}
  >
    Experimental — the API may change between minor releases
  </a>

  <h1
    class="mx-auto mt-6 max-w-3xl text-balance font-medium text-4xl tracking-tight sm:text-5xl lg:text-6xl"
  >
    <span class="block">Open any layer</span>
    <span class="block text-accent">from anywhere.</span>
  </h1>

  <p class="mx-auto mt-6 max-w-2xl text-balance text-foreground text-lg">
    Stop prop-drilling <code class="rounded bg-muted px-1 font-mono text-sm">isOpen</code> and threading <code class="rounded bg-muted px-1 font-mono text-sm">onConfirm</code> callbacks through your tree.
  </p>

  <p class="mx-auto mt-4 max-w-2xl text-balance text-muted-foreground">
    Modals, drawers, toasts, and confirms as named, ordered stacks — open one from any component, effect, or route guard and <code class="rounded bg-muted px-1 font-mono text-sm">await</code> a typed result. Headless core, seven framework adapters.
  </p>

  <div class="mx-auto mt-8 flex items-center justify-center gap-10">
    <div>
      <div class="font-bold text-3xl text-foreground">7</div>
      <div class="text-muted-foreground text-xs">adapters</div>
    </div>
    <div>
      <div class="font-bold text-3xl text-foreground">8</div>
      <div class="text-muted-foreground text-xs">live examples</div>
    </div>
    <div>
      <div class="font-bold text-3xl text-foreground">zero-dep</div>
      <div class="text-muted-foreground text-xs">core</div>
    </div>
  </div>

  <div
    class="mx-auto mt-8 flex max-w-2xl flex-wrap items-center justify-center gap-2"
    data-framework-pills
  >
    {
      adapterSnippets.map((snippet) => (
        <button
          class={`inline-flex items-center gap-1.5 ${pillBase} ${snippet.framework === defaultFramework ? pillActive : pillMuted}`}
          data-framework={snippet.framework}
          data-install-command={snippet.installCommand}
          type="button"
        >
          <Icon name={snippet.icon} size={16} />
          {snippet.label}
        </button>
      ))
    }
  </div>

  <div class="mx-auto mt-6 max-w-2xl text-left">
    {
      adapterSnippets.map((snippet) => (
        <div
          class={snippet.framework === defaultFramework ? undefined : "hidden"}
          data-code={snippet.framework}
        >
          <CodeBlock code={snippet.code} lang={snippet.lang} />
        </div>
      ))
    }
  </div>

  <div class="mt-9"><InstallBox /></div>

  <div class="mt-7 flex items-center justify-center gap-6 text-sm">
    <a
      class="inline-flex items-center gap-1 rounded-blume bg-accent px-5 py-2.5 font-medium text-accent-foreground text-sm transition-opacity hover:opacity-90"
      href={contentHref("/guides/getting-started")}
    >
      Get started
      <svg
        class="size-3.5"
        fill="none"
        height="14"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        viewBox="0 0 24 24"
        width="14"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="m9 18 6-6-6-6"></path>
      </svg>
    </a>
    <a
      class="inline-flex items-center gap-1 font-medium text-muted-foreground transition-colors hover:text-foreground"
      href="https://github.com/stainless-code/layers"
      rel="noreferrer"
      target="_blank"
    >
      View the code
      <svg
        class="size-3.5"
        fill="none"
        height="14"
        stroke="currentColor"
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        viewBox="0 0 24 24"
        width="14"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="m9 18 6-6-6-6"></path>
      </svg>
    </a>
  </div>

  <div class="mx-auto mt-12 max-w-6xl text-left">
    <div class="mx-auto mb-6 max-w-2xl text-center">
      <h2 class="font-medium text-3xl tracking-tight sm:text-4xl">
        Try it live.
      </h2>
      <p class="mx-auto mt-3 max-w-lg text-balance text-muted-foreground text-sm">
        Modals are just async functions you forgot to <code
          class="rounded bg-muted px-1 font-mono text-xs">await</code
        >. Open a confirm, toast, or serial flow below and watch the stack and
        lifecycle update live in the inspector.
      </p>
    </div>
    <HeroDemo client:load />
  </div>
</section>

<script is:inline>
  (() => {
    const pillContainer = document.querySelector("[data-framework-pills]");
    const installBox = document.querySelector("[data-blume-install-box]");
    if (!pillContainer) return;

    const ACTIVE = ["border-accent", "bg-accent/10", "font-medium", "text-accent"];
    const MUTED = [
      "border-border",
      "text-muted-foreground",
      "hover:border-foreground/40",
      "hover:text-foreground",
    ];

    pillContainer.addEventListener("click", (e) => {
      const pill = e.target.closest("[data-framework]");
      if (!pill) return;

      const framework = pill.dataset.framework;
      const installCommand = pill.dataset.installCommand;

      pillContainer.querySelectorAll("[data-framework]").forEach((p) => {
        const isActive = p.dataset.framework === framework;
        p.classList.remove(...ACTIVE, ...MUTED);
        p.classList.add(...(isActive ? ACTIVE : MUTED));
      });

      document.querySelectorAll("[data-code]").forEach((block) => {
        if (block.dataset.code === framework) {
          block.classList.remove("hidden");
        } else {
          block.classList.add("hidden");
        }
      });

      if (installBox && installCommand) {
        const codeEl = installBox.querySelector("code");
        const copyBtn = installBox.querySelector("[data-blume-copy-install]");
        if (codeEl) codeEl.textContent = installCommand;
        if (copyBtn) copyBtn.dataset.command = installCommand;
      }
    });
  })();
</script>
