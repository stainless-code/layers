{
  "name": "@stainless-code/alpine-layers",
  "version": "0.2.2",
  "description": "Alpine.js adapter for @stainless-code/layers — call a layer like an async function and await its response.",
  "keywords": [
    "alpine",
    "alpinejs",
    "dialog",
    "drawer",
    "headless",
    "layer",
    "modal",
    "popover",
    "stack",
    "tanstack-intent",
    "typescript"
  ],
  "homepage": "https://stainless-code.com/layers/adapters/alpine",
  "bugs": {
    "url": "https://github.com/stainless-code/layers/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stainless-code/layers.git",
    "directory": "packages/alpine"
  },
  "funding": "https://github.com/sponsors/SutuSebastian",
  "files": [
    "dist",
    "skills",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test-d.ts"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/cdn.mjs",
    "./src/cdn.ts"
  ],
  "unpkg": "./dist/cdn.mjs",
  "exports": {
    ".": {
      "@stainless-code/source": "./src/index.ts",
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./cdn": {
      "@stainless-code/source": "./src/cdn.ts",
      "types": "./dist/cdn.d.mts",
      "import": "./dist/cdn.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "check:pack": "attw --pack . --profile esm-only && publint --strict",
    "test": "bun test ./src",
    "test:coverage": "bun test ./src --coverage --coverage-threshold=0.75",
    "test:dom": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stainless-code/layers": "workspace:*"
  },
  "devDependencies": {
    "alpinejs": "3.15.12",
    "jsdom": "29.1.1",
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "@alpinejs/focus": ">=3.13.0",
    "alpinejs": ">=3.13.0"
  },
  "peerDependenciesMeta": {
    "@alpinejs/focus": {
      "optional": true
    }
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": "^20.19.0 || >=22.12.0"
  }
}
